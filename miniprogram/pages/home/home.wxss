/* ========================================
   梦境感横条效果
   ======================================== */

.skin-princess-castle .dream-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 12rpx;
    overflow: hidden;
    pointer-events: none;
    z-index: 20;
    border-radius: 24rpx 24rpx 0 0;
}
.skin-princess-castle .dream-shimmer {
    position: absolute;
    top: 0;
    left: -100%;
    width: 200%;
    height: 100%;
    background: linear-gradient(
        90deg,
        transparent 0%,
        rgba(255, 229, 139, 0.3) 25%,
        rgba(216, 231, 255, 0.4) 50%,
        rgba(255, 214, 231, 0.3) 75%,
        transparent 100%
    );
    animation: shimmer-slide 4s ease-in-out infinite;
}

@keyframes shimmer-slide {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(50%); }
}

.skin-princess-castle .dream-glow {
    position: absolute;
    top: -2rpx;
    left: 0;
    right: 0;
    height: 12rpx;
    background: radial-gradient(
        ellipse at center,
        rgba(255, 229, 139, 0.2) 0%,
        transparent 70%
    );
    opacity: 0.6;
    animation: glow-pulse 3s ease-in-out infinite;
}

@keyframes glow-pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.8; }
}

.skin-princess-castle .dream-particle {
    position: absolute;
    top: -4rpx;
    font-size: 16rpx;
    color: rgba(255, 229, 139, 0.7);
    opacity: 0;
    animation: particle-float 5s ease-in-out infinite;
}

.skin-princess-castle .dream-particle.particle-1 {
    left: 15%;
    animation-delay: 0s;
}

.skin-princess-castle .dream-particle.particle-2 {
    left: 50%;
    animation-delay: 1.5s;
}

.skin-princess-castle .dream-particle.particle-3 {
    left: 85%;
    animation-delay: 3s;
}

@keyframes particle-float {
    0%, 100% { 
        opacity: 0; 
        transform: translateY(0) scale(0.5);
    }
    25% { 
        opacity: 0.8; 
        transform: translateY(-6rpx) scale(1);
    }
    50% { 
        opacity: 0.6; 
        transform: translateY(-8rpx) scale(0.9);
    }
    75% { 
        opacity: 0.3; 
        transform: translateY(-6rpx) scale(0.7);
    }
}

