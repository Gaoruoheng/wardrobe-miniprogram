/* 每一个衣柜空白处的独特梦幻底纹 (利用 nth-child 区分不同卡片) */
.skin-princess-castle .wardrobe-card::before {
    content: "";
    position: absolute;
    right: 30rpx;
    bottom: 20rpx;
    width: 140rpx;
    height: 140rpx;
    background-size: contain;
    background-repeat: no-repeat;
    background-position: bottom right;
    opacity: 0.12;
    z-index: 1;
    pointer-events: none;
}

.skin-princess-castle .wardrobe-card:nth-child(5n+1)::before {
    /* 玫瑰与星辰底纹 */
    background-image: radial-gradient(circle at center, rgba(232, 156, 197, 0.8) 0%, transparent 60%),
                      linear-gradient(135deg, transparent 40%, rgba(207, 169, 232, 0.4) 45%, transparent 50%);
    border-radius: 50%;
}

.skin-princess-castle .wardrobe-card:nth-child(5n+2)::before {
    /* 纸飞机/纸鹤底纹 */
    background-image: linear-gradient(135deg, transparent 20%, rgba(168, 196, 232, 0.8) 50%, transparent 80%);
    clip-path: polygon(0 50%, 100% 0, 80% 100%);
}

.skin-princess-castle .wardrobe-card:nth-child(5n+3)::before {
    /* 王冠底纹 */
    background-image: linear-gradient(180deg, rgba(255, 229, 139, 0.9), rgba(201, 150, 53, 0.4));
    clip-path: polygon(10% 100%, 0 20%, 30% 60%, 50% 0, 70% 60%, 100% 20%, 90% 100%);
    height: 80rpx;
}

.skin-princess-castle .wardrobe-card:nth-child(5n+4)::before {
    /* 魔法阵底纹 */
    background-image: repeating-conic-gradient(from 0deg, rgba(207, 169, 232, 0.2) 0deg 15deg, transparent 15deg 30deg);
    border: 4rpx solid rgba(207, 169, 232, 0.4);
    border-radius: 50%;
}

.skin-princess-castle .wardrobe-card:nth-child(5n+5)::before {
    /* 贝壳底纹 */
    background-image: radial-gradient(ellipse at bottom, rgba(255, 214, 231, 0.9) 0%, transparent 70%);
    clip-path: polygon(50% 0%, 100% 20%, 90% 80%, 50% 100%, 10% 80%, 0% 20%);
}

