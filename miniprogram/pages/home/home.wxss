.admin-fixed-btn {
    position: fixed !important;
    bottom: 100rpx;
    right: 24rpx;
    width: 100rpx;
    height: 100rpx;
    border-radius: 50%;
    background: rgba(81,64,153,0.85);
    color: #ffffff;
    font-size: 28rpx;
    font-weight: bold;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 99999;
    box-shadow: 0 8rpx 24rpx rgba(81,64,153,0.4);
    backdrop-filter: blur(8px);
