/* ====================================================
   公主城堡衣橱 主题重写 (同步 Home)
   ==================================================== */
.app-container.skin-princess-castle {
    background: radial-gradient(circle at 12% 8%, rgba(255,210,221,.85) 0, rgba(255,210,221,0) 190rpx), radial-gradient(circle at 92% 18%, rgba(205,238,226,.75) 0, rgba(205,238,226,0) 180rpx), linear-gradient(180deg, #fff2e8, #fffaf5 44%, #fff7ef);
}

.app-container.skin-princess-castle .top-header .header-gradient {
    background: linear-gradient(135deg, rgba(255,255,255,0.8), rgba(255,248,252,0.9));
    border-bottom: 2rpx solid rgba(207, 169, 232, 0.4);
    box-shadow: 0 10rpx 20rpx rgba(116,82,143,0.06);
}

.app-container.skin-princess-castle .header-character,
.app-container.skin-princess-castle .soft-cloud,
.app-container.skin-princess-castle .bg-orb,
.app-container.skin-princess-castle .bg-star {
    display: none !important;
}

/* 用新的华丽设计替代顶部 Header */
.app-container.skin-princess-castle .top-header::before {
    content: "";
    position: absolute;
    left: 20rpx;
    right: 20rpx;
    top: 20rpx;
    bottom: 20rpx;
    border-radius: 40rpx;
    border: 2rpx solid rgba(184,138,51,0.25);
    background: repeating-linear-gradient(90deg, rgba(207,169,232,0.08) 0 2rpx, transparent 2rpx 20rpx);
    z-index: 1;
    pointer-events: none;
}

.app-container.skin-princess-castle .tiny-label {
    background: linear-gradient(135deg, #fffcf3, #fff6d8);
    border: 1rpx solid rgba(184, 138, 51, 0.3);
    color: #a96c36;
    box-shadow: 0 4rpx 8rpx rgba(184, 138, 51, 0.1);
}

.app-container.skin-princess-castle .item-card {
    background: linear-gradient(110deg,rgba(255,255,255,.9),rgba(255,255,255,.65) 46%,rgba(255,243,251,.85));
    border: 1rpx solid rgba(109,80,135,.15);
    border-radius: 24rpx;
    box-shadow: 0 8rpx 16rpx rgba(81,64,153,.06);
}

/* 内部面板的标签和按钮 */
